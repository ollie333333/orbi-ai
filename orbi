cat > orbi/main.py << 'EOF'
import sys, os, shutil, subprocess, requests, colorsys
from PySide6.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout, QTextEdit,
    QLineEdit, QPushButton, QListWidget, QListWidgetItem,
    QMessageBox, QComboBox
)
from PySide6.QtCore import Qt, QThread, Signal, QTimer

# ---------------------------
# Ollama check
# ---------------------------
if shutil.which("ollama") is None:
    print("Ollama not found. Installing via Homebrew...")
    try:
        subprocess.run(["brew","install","ollama"], check=True)
    except subprocess.CalledProcessError:
        print("Failed to install Ollama. Install manually: https://ollama.com/download")
        sys.exit(1)

CHAT_DIR = "chats"
MEMORY_FILE = "orbi_memory.txt"

# ---------------------------
# Pulsing rainbow text
# ---------------------------
hue_offset = 0
text_mode = "rainbow"  # default

def rainbow_html(text, hue_shift):
    html=""
    for i,c in enumerate(text):
        hue=(i*40 + hue_shift)%360
        html+=f'<span style="color:hsl({hue},100%,70%); font-weight:bold">{c}</span>'
    return html

def color_text(text):
    if text_mode=="rainbow":
        return rainbow_html(text,hue_offset)
    elif text_mode=="blue":
        return f'<span style="color:#1E90FF; font-weight:bold">{text}</span>'
    elif text_mode=="black":
        return f'<span style="color:#000000; font-weight:bold">{text}</span>'
    return text

# ---------------------------
# Llama3 runner
# ---------------------------
class LlamaThread(QThread):
    finished = Signal()
    def run(self):
        try:
            requests.get("http://127.0.0.1:11434")
        except:
            print("Starting Llama3 server...")
            subprocess.Popen(["ollama","run","llama3"])
            import time; time.sleep(5)
        self.finished.emit()

# ---------------------------
# Main App
# ---------------------------
class OrbiApp(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Orbi Assistant")
        self.setGeometry(200,100,900,600)
        self.setStyleSheet("background-color:#1e1e1e;")
        if not os.path.exists(CHAT_DIR): os.makedirs(CHAT_DIR)

        main_layout = QHBoxLayout()
        self.setLayout(main_layout)

        # Chat list
        self.chat_list = QListWidget(); self.chat_list.setFixedWidth(250)
        self.chat_list.itemClicked.connect(self.load_chat)
        main_layout.addWidget(self.chat_list)

        # Chat area
        chat_layout = QVBoxLayout()
        main_layout.addLayout(chat_layout)

        self.chat_display = QTextEdit(); self.chat_display.setReadOnly(True)
        self.chat_display.setStyleSheet("background-color:#1e1e1e; color:#ffffff; padding:10px; border-radius:5px;")
        chat_layout.addWidget(self.chat_display)

        # Input line
        self.input_line = QLineEdit(); self.input_line.setPlaceholderText("Ask Orbi...")
        self.input_line.returnPressed.connect(self.send_message)
        chat_layout.addWidget(self.input_line)

        # Buttons
        btn_layout = QHBoxLayout(); chat_layout.addLayout(btn_layout)
        self.send_btn = QPushButton("Send"); self.send_btn.clicked.connect(self.send_message); btn_layout.addWidget(self.send_btn)
        self.new_chat_btn = QPushButton("New Chat"); self.new_chat_btn.clicked.connect(self.new_chat); btn_layout.addWidget(self.new_chat_btn)
        self.reset_ai_btn = QPushButton("Reset AI & Exit"); self.reset_ai_btn.clicked.connect(self.reset_ai); btn_layout.addWidget(self.reset_ai_btn)
        self.reset_memory_btn = QPushButton("Reset Memory"); self.reset_memory_btn.clicked.connect(self.reset_memory); btn_layout.addWidget(self.reset_memory_btn)
        self.settings_btn = QPushButton("Settings"); self.settings_btn.clicked.connect(self.open_settings); btn_layout.addWidget(self.settings_btn)

        self.current_chat = None

        # Llama server
        self.llama_thread = LlamaThread()
        self.llama_thread.finished.connect(self.load_chat_list)
        self.llama_thread.start()

        # Timer for rainbow pulse
        self.pulse_timer = QTimer()
        self.pulse_timer.timeout.connect(self.update_pulse)
        self.pulse_timer.start(100)  # 10 fps

    # ---------------------------
    # Chat list & summary
    # ---------------------------
    def load_chat_list(self):
        self.chat_list.clear()
        if not os.path.exists(CHAT_DIR): os.makedirs(CHAT_DIR)
        for filename in os.listdir(CHAT_DIR):
            if filename.endswith(".txt"):
                summary=self.get_chat_summary(os.path.join(CHAT_DIR,filename))
                item=QListWidgetItem(summary); item.setData(Qt.UserRole,filename)
                self.chat_list.addItem(item)
        if self.chat_list.count()>0 and not self.current_chat:
            self.chat_list.setCurrentRow(0); self.load_chat(self.chat_list.currentItem())

    def get_chat_summary(self,filepath):
        try:
            with open(filepath,"r",encoding="utf-8") as f:
                lines=[l.strip() for l in f if l.strip()]
                return lines[-1][:50]+"…" if lines else "(Empty chat)"
        except: return "(Error reading chat)"

    def load_chat(self,item):
        filename=item.data(Qt.UserRole); self.current_chat=filename
        path=os.path.join(CHAT_DIR,filename)
        self.chat_display.setHtml(open(path,"r",encoding="utf-8").read() if os.path.exists(path) else "")

    def save_history(self,text):
        if not self.current_chat: return
        with open(os.path.join(CHAT_DIR,self.current_chat),"a",encoding="utf-8") as f: f.write(text+"\n")
        self.load_chat_list()

    # ---------------------------
    # Chat management
    # ---------------------------
    def new_chat(self):
        base="chat_"; idx=1
        while os.path.exists(os.path.join(CHAT_DIR,f"{base}{idx}.txt")): idx+=1
        self.current_chat=f"{base}{idx}.txt"; open(os.path.join(CHAT_DIR,self.current_chat),"w",encoding="utf-8").close()
        self.load_chat_list(); self.chat_display.clear()

    def reset_ai(self):
        reply=QMessageBox.question(self,"Reset AI","Delete all chats/memory and exit?",QMessageBox.Yes|QMessageBox.No)
        if reply==QMessageBox.Yes:
            self.current_chat=None; self.chat_display.clear(); self.chat_list.clear()
            if os.path.exists(CHAT_DIR):
                for f in os.listdir(CHAT_DIR): os.remove(os.path.join(CHAT_DIR,f))
            if os.path.exists(MEMORY_FILE): os.remove(MEMORY_FILE)
            os.makedirs(CHAT_DIR,exist_ok=True); open(MEMORY_FILE,"w",encoding="utf-8").close()
            QApplication.quit()

    def reset_memory(self):
        reply=QMessageBox.question(self,"Reset Memory","Delete Orbi's memory?",QMessageBox.Yes|QMessageBox.No)
        if reply==QMessageBox.Yes:
            if os.path.exists(MEMORY_FILE): os.remove(MEMORY_FILE)
            open(MEMORY_FILE,"w",encoding="utf-8").close()

    # ---------------------------
    # Settings
    # ---------------------------
    def open_settings(self):
        global text_mode
        msg=QMessageBox()
        msg.setWindowTitle("Select Text Color Mode")
        combo=QComboBox(msg)
        combo.addItems(["rainbow","blue","black"])
        combo.setCurrentText(text_mode)
        combo.move(20,40)
        combo.show()
        def apply_choice():
            global text_mode
            text_mode=combo.currentText()
            msg.close()
        ok_btn=QPushButton("Apply",msg)
        ok_btn.move(20,70)
        ok_btn.clicked.connect(apply_choice)
        msg.setFixedSize(200,120)
        msg.exec()

    # ---------------------------
    # Message sending
    # ---------------------------
    def send_message(self):
        if not self.current_chat: self.new_chat()
        msg=self.input_line.text().strip()
        if not msg: return
        self.chat_display.append(color_text(f"You: {msg}")); self.save_history(f"You: {msg}")
        response=self.ask_orbi(msg); self.chat_display.append(color_text(f"Orbi: {response}")); self.save_history(f"Orbi: {response}")
        self.input_line.clear()
        self.chat_display.verticalScrollBar().setValue(self.chat_display.verticalScrollBar().maximum())

    def ask_orbi(self,prompt):
        mem=""
        if os.path.exists(MEMORY_FILE): mem=open(MEMORY_FILE,"r",encoding="utf-8").read()
        full=f"{mem}\nYou are Orbi Assistant, a friendly AI like ChatGPT.\nUser: {prompt}"
        try:
            r=requests.post("http://127.0.0.1:11434/api/generate",json={"model":"llama3","prompt":full,"stream":False})
            resp=r.json().get("response","Sorry, no response.")
            with open(MEMORY_FILE,"a",encoding="utf-8") as f: f.write(f"User: {prompt}\nOrbi: {resp}\n")
            return resp
        except Exception as e: return f"Error: {e}"

    # ---------------------------
    # Rainbow pulse update
    # ---------------------------
    def update_pulse(self):
        global hue_offset
        if text_mode=="rainbow":
            hue_offset=(hue_offset+2)%360
            cursor=self.chat_display.textCursor()
            cursor.movePosition(cursor.Start)
            plain=self.chat_display.toPlainText()
            self.chat_display.setHtml(color_text(plain))
            self.chat_display.verticalScrollBar().setValue(self.chat_display.verticalScrollBar().maximum())

def run():
    app=QApplication(sys.argv); window=OrbiApp(); window.show(); sys.exit(app.exec())

if __name__=="__main__": run()
EOF

